MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5a7fbe1532613674eae711d98ba55f4c, type: 3}
  m_Name: Duel_Conversation
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Stan
    sentence: Hey Apolonia! Thanks for agreeing to spar with me today.
  - speakerName: Apolonia
    sentence: Of course, Stan! I could use a good workout. Let's do this!
  - speakerName: Stan
    sentence: Alright, just so you know... I won't be holding back. I want to see
      your real skills!
  - speakerName: Apolonia
    sentence: Good! I wouldn't want it any other way. I'll give you everything I've
      got!
  - speakerName: Stan
    sentence: That's what I like to hear! Keep your stance low and watch my feints.
  - speakerName: Apolonia
    sentence: I'll keep that in mind. Your sword skill is always tricky to read.
  - speakerName: Stan
    sentence: Thanks, but I'm sure you've gotten faster since the last time we trained!
  - speakerName: Apolonia
    sentence: Let's just say I've had a lot of practice. I'm ready to surprise you!
  - speakerName: Stan
    sentence: Heh. I love that confidence! Position yourself, partner. Let's start!
  - speakerName: Apolonia
    sentence: I'm right here! Don't blink, Stan... here I come!
